{
  "name": "school-subscription-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:setup": "npm run db:push && npm run dev -- --port 3002",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "node --env-file=.env scripts/prisma-local-push.mjs",
    "db:deploy": "node --env-file=.env scripts/prisma-prod-deploy.mjs",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "mobile:sync": "cap sync",
    "mobile:sync:all": "cap sync ios && cap sync android",
    "mobile:sync:ios:live": "CAPACITOR_SERVER_URL=${CAPACITOR_SERVER_URL:-http://localhost:3000} cap sync ios",
    "mobile:open:ios": "cap open ios",
    "mobile:open:android": "cap open android",
    "mobile:build": "rm -rf .next && next build && cap sync",
    "mobile:build:ios": "rm -rf .next && next build && cap sync ios",
    "mobile:prepare:ios": "npm run mobile:build:ios && cap open ios",
    "mobile:build:android": "rm -rf .next && next build && cap sync android",
    "mobile:build:android:clean": "rm -rf .next && next build && cap sync android && cd android && ./gradlew clean assembleDebug",
    "mobile:run:ios:live": "CAPACITOR_SERVER_URL=${CAPACITOR_SERVER_URL:-http://localhost:3000} cap run ios",
    "platform:compat": "npm run build && npm run mobile:sync:all",
    "platform:release-ready": "npm run platform:compat && npm run mobile:build:android && npm run mobile:build:ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-native-biometric": "^8.4.2",
    "@prisma/client": "^6.7.0",
    "@prisma/engines": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jose": "^5.10.0",
    "next": "^15.3.0",
    "next-pwa": "^5.6.0",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.12"
    },
    "rollup-plugin-terser": {
      "serialize-javascript": "^7.0.5"
    }
  }
}
