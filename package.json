{
  "name": "school-subscription-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:setup": "npm run db:push && npm run dev -- --port 3002",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prisma:generate": "prisma generate",
    "mobile:sync": "cap sync",
    "mobile:open:ios": "cap open ios",
    "mobile:open:android": "cap open android",
    "mobile:build": "rm -rf .next && next build && cap sync",
    "mobile:build:ios": "rm -rf .next && next build && cap sync ios",
    "mobile:build:android": "rm -rf .next && next build && cap sync android",
    "mobile:build:android:clean": "rm -rf .next && next build && cap sync android && cd android && ./gradlew clean assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/keyboard": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^6.7.0",
    "@prisma/engines": "^7.7.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "jose": "^5.10.0",
    "next": "^15.3.0",
    "next-pwa": "^5.6.0",
    "nodemailer": "^8.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
