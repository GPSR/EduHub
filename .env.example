# Local development database (Prisma)
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schools_local?schema=public"

# Optional compatibility fallback
DATABASE_URL=""

# Production database (Neon PostgreSQL)
NEON_DATABASE_URL=""

# Deployment environment:
# - stage (uses current staging DNS: stgae.*)
# - production
APP_ENV="production"

# Optional explicit app URLs (override APP_ENV defaults when needed)
SCHOOL_APP_BASE_URL=""
PLATFORM_APP_BASE_URL=""

AUTH_SECRET="replace-with-a-long-random-string"

# --- Email provider (configure one option) ---
# Option 1: Resend
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# Option 2: Zoho SMTP
ZOHO_SMTP_USER=""
ZOHO_SMTP_PASS=""
ZOHO_SMTP_HOST="smtp.zoho.com"
ZOHO_SMTP_PORT="465"
ZOHO_SMTP_SECURE="true"
ZOHO_FROM_EMAIL=""

# --- Optional SMS (Twilio) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
TWILIO_DEFAULT_TO=""
