# Local development database (Prisma)
LOCAL_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schools_local?schema=public"

# Optional compatibility fallback
DATABASE_URL=""

# Production database (Neon PostgreSQL)
NEON_DATABASE_URL=""

# Deployment environment:
# - stage (uses current staging DNS: stgae.*)
# - production
APP_ENV="production"

# Optional explicit app URLs (override APP_ENV defaults when needed)
SCHOOL_APP_BASE_URL=""
PLATFORM_APP_BASE_URL=""

AUTH_SECRET="replace-with-a-long-random-string"
